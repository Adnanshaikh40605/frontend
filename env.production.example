# Frontend environment variables for production
# Copy these values to your Vercel environment variables

# API base URL for production
VITE_API_BASE_URL=https://backend-production-0150.up.railway.app

# Media URL for serving images and uploads
VITE_MEDIA_URL=https://backend-production-0150.up.railway.app/media/

# Set to false in production
VITE_USE_MOCK_API=false

# Debug mode (disable in production)
VITE_DEBUG=false 